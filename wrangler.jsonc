{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mi-prueba-tecnica",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-04-08",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "r2_buckets": [
    {
      "binding": "NEXT_CACHE_WORKERS_R2",
      "bucket_name": "mi-cache-nextjs" 
    }
  ],
  "observability": {
    "enabled": true
  }
}